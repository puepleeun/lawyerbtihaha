/* ═══════════════════════════════════════════
   STATE
═══════════════════════════════════════════ */
let currentQ = 0;
let answers  = [];  // stores option index (0,1,2)

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(id);
  el.classList.add('active');
  el.scrollTop = 0;
}

function startQuiz() {
  currentQ = 0;
  answers  = [];
  showScreen('s-quiz');
  renderQuestion(0);
}

function restartQuiz() {
  showScreen('s-intro');
}

/* ═══════════════════════════════════════════
   QUIZ LOGIC
═══════════════════════════════════════════ */
function renderQuestion(idx) {
  const q = QUESTIONS[idx];
  const total = QUESTIONS.length;

  // Progress
  document.getElementById('q-count').textContent = `${idx + 1} / ${total}`;
  document.getElementById('prog-bar').style.width = `${((idx) / total) * 100}%`;
  document.getElementById('q-num').textContent = `Q.${String(idx + 1).padStart(2, '0')}`;
  document.getElementById('q-text').textContent = q.q;

  // Options
  const labels = ['A', 'B', 'C'];
  const optsEl = document.getElementById('opts');
  optsEl.innerHTML = '';
  q.opts.forEach((txt, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt';
    btn.innerHTML = `<span class="opt-abc">${labels[i]}</span><span class="opt-text">${txt}</span>`;
    btn.onclick = () => selectOption(i);
    optsEl.appendChild(btn);
  });
}

function selectOption(optIdx) {
  const opts = document.querySelectorAll('.opt');
  opts.forEach((b, i) => {
    b.classList.toggle('selected', i === optIdx);
    b.classList.toggle('dimmed', i !== optIdx);
    b.onclick = null; // prevent double tap
  });

  // flash feedback
  const flash = document.getElementById('flash');
  flash.classList.add('on');
  setTimeout(() => flash.classList.remove('on'), 80);

  answers[currentQ] = optIdx;

  setTimeout(() => {
    if (currentQ < QUESTIONS.length - 1) {
      const wrap = document.getElementById('q-wrap');
      wrap.classList.add('out-left');
      setTimeout(() => {
        currentQ++;
        renderQuestion(currentQ);
        wrap.classList.remove('out-left');
        wrap.style.opacity = '0';
        wrap.style.transform = 'translateX(20px)';
        setTimeout(() => {
          wrap.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
          wrap.style.opacity = '1';
          wrap.style.transform = 'translateX(0)';
        }, 20);
      }, 220);
    } else {
      // Last question
      setTimeout(showResult, 300);
    }
  }, 420);
}

/* ═══════════════════════════════════════════
   SCORING & RESULT
═══════════════════════════════════════════ */
function calcScore() {
  let total = 0;
  QUESTIONS.forEach((q, i) => {
    const opt = answers[i] ?? 1; // default mid
    const pts = q.fwd ? (opt + 1) : (3 - opt);
    total += pts;
  });
  return total;
}

function getType(score) {
  // Hidden TRAP: Q11 = C (idx 2) AND Q1 = A (idx 0)
  if (answers[10] === 2 && answers[0] === 0) return TRAP_TYPE;

  for (const t of TYPES) {
    if (score >= t.min && score <= t.max) return t;
  }
  return TYPES[TYPES.length - 1];
}

/* ═══════════════════════════════════════════
   WECHAT SHARE
═══════════════════════════════════════════ */
function wechatShare() {
  // In WeChat browser, trigger native share menu
  if (navigator.share) {
    navigator.share({
      title: 'LBTI · 律师行为类型测试',
      text: '15道题，测出你的律师人格类型。不评判，不安慰，只是把你看个透。',
      url: window.location.href
    }).catch(() => {});
  } else {
    // Fallback: hint user to use WeChat share
    alert('点击右上角 ··· 分享给朋友或发到朋友圈');
  }
}

function showResult() {
  const score = calcScore();
  const type  = getType(score);

  document.getElementById('res-code').textContent = type.code;
  document.getElementById('res-code').style.color = type.color;
  document.getElementById('res-name').textContent = type.name;
  document.getElementById('res-score-tag').textContent = `得分 ${score} · LBTI™`;
  document.getElementById('res-glow').style.background = type.color;
  document.getElementById('res-card-top').style.background = `linear-gradient(90deg, ${type.color}, transparent)`;
  document.getElementById('res-desc').textContent = type.desc;

  // Meta rows
  const metaEl = document.getElementById('res-meta');
  metaEl.innerHTML = `
    <div class="res-meta-row">
      <span class="res-meta-key">代表动作</span>
      <span class="res-meta-val">${type.action}</span>
    </div>
    <div class="res-meta-row">
      <span class="res-meta-key">常说的话</span>
      <span class="res-meta-val">${type.word}</span>
    </div>
    <div class="res-meta-row">
      <span class="res-meta-key">最大心愿</span>
      <span class="res-meta-val">${type.wish}</span>
    </div>
  `;

  // Final progress fill
  document.getElementById('prog-bar').style.width = '100%';

  showScreen('s-result');
}
